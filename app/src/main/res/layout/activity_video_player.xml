<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <View
        android:id="@+id/click_interceptor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/seek_bar"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Область клика для управления" />

    <!-- Счетчик упражнений с круговым таймером (верхний правый) -->
    <FrameLayout
        android:id="@+id/layout_counter_container"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="60dp"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/circular_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:indicatorColor="#FFEB3B"
            app:trackColor="#40FFFFFF"
            app:indicatorSize="150dp"
            app:trackThickness="8dp" />

        <!-- Контейнер для риски (палочки), которая делает оборот за время шага -->
        <FrameLayout
            android:id="@+id/layout_stick_container"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center">

            <View
                android:id="@+id/circular_stick"
                android:layout_width="5dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal|top"
                android:background="#669900" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_exercise_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FFEB3B"
            android:textSize="42sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />
    </FrameLayout>

    <!-- Панель управления упражнением (слева) -->
    <LinearLayout
        android:id="@+id/layout_exercise_controls"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        android:background="#A0000000"
        android:padding="12dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tv_control_segment_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00 - 00:00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_exercise_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Включить"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/layout_settings_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЛИМИТ (MAX):"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:layout_marginTop="8dp" />
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_control_max_min"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/editbox_background_normal"
                    android:gravity="center"
                    android:text="00"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
                <TextView
                    android:id="@+id/tv_control_max_sec"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/editbox_background_normal"
                    android:gravity="center"
                    android:text="00"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ШАГ ПРИБАВКИ:"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:layout_marginTop="8dp" />
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_control_step_min"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/editbox_background_normal"
                    android:gravity="center"
                    android:text="00"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
                <TextView
                    android:id="@+id/tv_control_step_sec"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/editbox_background_normal"
                    android:gravity="center"
                    android:text="00"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Множитель:"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:layout_marginTop="8dp" />
            <TextView
                android:id="@+id/tv_control_mult"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@android:drawable/editbox_background_normal"
                android:gravity="center"
                android:text="--"
                android:textColor="#000000"
                android:textSize="18sp" />

            <!-- Кнопки Сохранить и Удалить рядом -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_control_save"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="Сохранить"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:backgroundTint="#669900" />
                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_control_delete"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="Удалить"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:backgroundTint="#CC0000" />
            </LinearLayout>

            <!-- Общие настройки -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_control_general_settings"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="Общие настройки"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                app:backgroundTint="#757575" />
        </LinearLayout>
    </LinearLayout>

    <!-- Контейнер для рисок (над SeekBar) -->
    <FrameLayout
        android:id="@+id/layout_ticks"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="2dp"
        android:elevation="2dp" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_alignParentBottom="true"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_marginBottom="2dp"
        android:thumb="@null"
        android:splitTrack="false"
        android:progressDrawable="@android:drawable/progress_horizontal" />

    <!-- Кнопки Назад / Секундомер / Вперед -->
    <LinearLayout
        android:id="@+id/layout_bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5">

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_skip_previous"
            android:background="@drawable/bg_video_control"
            app:tint="#FFFFFF"
            android:scaleType="fitCenter"
            android:padding="12dp"
            android:alpha="0.8"
            android:contentDescription="Предыдущий отрезок" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Секундомер внизу -->
        <LinearLayout
            android:id="@+id/layout_bottom_stopwatch"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_video_control"
            android:padding="8dp">
            
            <TextView
                android:id="@+id/tv_bottom_stopwatch_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:alpha="1.0" />

            <TextView
                android:id="@+id/tv_stopwatch_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="СЕКУНДОМЕР"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:alpha="0.8"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_skip_next"
            android:background="@drawable/bg_video_control"
            app:tint="#FFFFFF"
            android:scaleType="fitCenter"
            android:padding="12dp"
            android:alpha="0.8"
            android:contentDescription="Следующий отрезок" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_pause_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПАУЗА"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="#40000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_stop"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_margin="12dp"
        android:src="@drawable/ic_stop_custom"
        android:background="@drawable/bg_video_control"
        app:tint="#FFFFFF"
        android:scaleType="fitCenter"
        android:padding="16dp"
        android:alpha="0.8"
        android:visibility="gone"
        android:contentDescription="Остановить" />

    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/seek_bar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:alpha="0.5" />

</RelativeLayout>
