<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <View
        android:id="@+id/click_interceptor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/seek_bar"
        android:clickable="true"
        android:focusable="true" />

    <!-- Счетчик упражнений с круговым таймером (верхний правый) -->
    <FrameLayout
        android:id="@+id/layout_counter_container"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="80dp"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/circular_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:indicatorColor="#FFEB3B"
            app:trackColor="#40FFFFFF"
            app:indicatorSize="100dp"
            app:trackThickness="4dp" />

        <!-- Контейнер для риски (палочки), которая делает оборот за время шага -->
        <FrameLayout
            android:id="@+id/layout_stick_container"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center">

            <View
                android:id="@+id/circular_stick"
                android:layout_width="3dp"
                android:layout_height="10dp"
                android:layout_gravity="center_horizontal|top"
                android:background="#A0A0A0" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_exercise_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FFEB3B"
            android:textSize="28sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />
    </FrameLayout>

    <!-- Контейнер для рисок (над SeekBar) -->
    <FrameLayout
        android:id="@+id/layout_ticks"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="2dp"
        android:elevation="2dp" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_alignParentBottom="true"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_marginBottom="2dp"
        android:thumb="@null"
        android:splitTrack="false"
        android:progressDrawable="@android:drawable/progress_horizontal" />

    <!-- Кнопки Назад / Секундомер / Вперед -->
    <LinearLayout
        android:id="@+id/layout_bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5">

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="&lt;&lt;"
            android:alpha="0.5" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Секундомер внизу -->
        <LinearLayout
            android:id="@+id/layout_bottom_stopwatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:padding="4dp"
            android:visibility="gone">
            
            <TextView
                android:id="@+id/tv_bottom_stopwatch_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:alpha="0.9" />
                
            <Button
                android:id="@+id/btn_stopwatch_toggle"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:text="START"
                android:textSize="10sp"
                android:alpha="0.7"
                android:padding="0dp" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="&gt;&gt;"
            android:alpha="0.5" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />
    </LinearLayout>

    <!-- Кнопка "Упражнения" -->
    <Button
        android:id="@+id/btn_exercise_menu"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="20dp"
        android:text="Упражнения"
        android:textSize="10sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:backgroundTint="#80444444"
        android:textColor="#FFFFFF"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layout_pause_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПАУЗА"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="#40000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПРОДОЛЖИТЬ"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:background="#40000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_margin="12dp"
        android:text="Стоп"
        android:alpha="0.7"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/seek_bar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:alpha="0.5" />

</RelativeLayout>
