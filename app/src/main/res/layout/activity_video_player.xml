<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <VideoView
        android:id="@+id/video_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <View
        android:id="@+id/click_interceptor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/seek_bar"
        android:clickable="true"
        android:focusable="true" />

    <!-- Счетчик упражнений с круговым таймером -->
    <FrameLayout
        android:id="@+id/layout_counter_container"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="80dp"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/circular_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:indicatorColor="#FFEB3B"
            app:trackColor="#40FFFFFF"
            app:indicatorSize="70dp"
            app:trackThickness="4dp" />

        <TextView
            android:id="@+id/tv_exercise_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FFEB3B"
            android:textSize="28sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />
    </FrameLayout>

    <!-- Контейнер для рисок (над SeekBar) -->
    <FrameLayout
        android:id="@+id/layout_ticks"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="2dp"
        android:elevation="2dp" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_alignParentBottom="true"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_marginBottom="2dp"
        android:thumb="@null"
        android:splitTrack="false"
        android:progressDrawable="@android:drawable/progress_horizontal" />

    <!-- Кнопки Назад / Вперед (разнесены от центра, расстояние 2/4 экрана) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="4">

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="&lt;&lt;"
            android:alpha="0.5" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="2" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="&gt;&gt;"
            android:alpha="0.5" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
    </LinearLayout>

    <!-- Кнопка "Упражнения" (снизу слева) -->
    <Button
        android:id="@+id/btn_exercise_menu"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="20dp"
        android:text="Упражнения"
        android:textSize="10sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:backgroundTint="#80444444"
        android:textColor="#FFFFFF"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layout_pause_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПАУЗА"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="#40000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПРОДОЛЖИТЬ"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:background="#40000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_margin="12dp"
        android:text="Стоп"
        android:alpha="0.7"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/seek_bar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:alpha="0.5" />

</RelativeLayout>
